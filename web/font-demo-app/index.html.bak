<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>CBF Font Viewer</title>
  <style>
    body {
      background-color: #0d1117;
      color: #c9d1d9;
      font-family: sans-serif;
      padding: 1em;
    }
    select, input {
      background: #161b22;
      color: #c9d1d9;
      border: 1px solid #30363d;
      padding: 0.5em;
      margin: 0.5em 0;
    }
    canvas {
      background: #0d1117;
      border: 1px solid #30363d;
      margin-top: 1em;
    }
  </style>
</head>
<body>
<h1>CBF Font Viewer</h1>

<label>Font:
  <select id="fontSelect">
    <option value="cc_red_alert_inet.cbf">cc_red_alert_inet.cbf</option>
    <option value="cc_red_alert_lan.cbf">cc_red_alert_lan.cbf</option>
  </select>
</label><br/>

<label>Scale:
  <select id="scaleSelect">
    <option value="1">1x</option>
    <option value="2" selected>2x</option>
    <option value="3">3x</option>
    <option value="4">4x</option>
  </select>
</label><br/>

<label>Text:
  <input type="text" id="inputText" value="HELLO WORLD!" />
</label><br/>

<pre id="metadata"></pre>
<canvas id="canvas" width="800" height="600"></canvas>

<script>
  const canvas = document.getElementById("canvas");
  const ctx = canvas.getContext("2d");
  let currentFont = null;

  async function loadFont(url) {
    const res = await fetch(url);
    const buf = await res.arrayBuffer();
    const view = new DataView(buf);

    if (view.getUint16(0, true) !== 0xF0CB || view.getUint16(2, true) !== 1) {
      throw new Error("Invalid file");
    }

    const header = [];
    for (let i = 0; i < 14; i++) header.push(view.getUint16(i * 2, true));

    const [
      , , fontNameSize, authorSize, charOrderSize, charWidthsSize,
      fontImageWidth, fontImageHeight, spacingProps,
      , , , year, monthDay
    ] = header;

    let offset = 28;

    const readStr = (len) => {
      const str = new TextDecoder().decode(new Uint8Array(buf, offset, len));
      offset += len;
      return str;
    };

    const fontName = readStr(fontNameSize);
    const author = readStr(authorSize);
    const charOrderStr = readStr(charOrderSize);
    const charOrder = Array.from(charOrderStr);

    const widths = new Uint8Array(buf, offset, charWidthsSize);
    offset += charWidthsSize;

    const kerning = spacingProps & 0xFF;
    const leading = spacingProps >> 8;

    const rowBytes = Math.ceil(fontImageWidth / 8);
    const image = [];
    const bitmap = new Uint8Array(buf, offset);
    for (let y = 0; y < fontImageHeight; y++) {
      const row = [];
      for (let x = 0; x < fontImageWidth; x++) {
        const byte = bitmap[y * rowBytes + (x >> 3)];
        const bit = (byte >> (7 - (x % 8))) & 1;
        row.push(bit);
      }
      image.push(row);
    }

    return {
      fontName, author, charOrder, widths, image,
      fontImageWidth, fontImageHeight, kerning, leading,
      year, month: monthDay >> 8, day: monthDay & 0xFF,
    };
  }

  function renderText(text, scale) {
    if (!currentFont) return;

    canvas.width = 800;
    canvas.height = 600;
    ctx.fillStyle = "#0d1117";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    const { charOrder, widths, image, kerning } = currentFont;
    const xOffsets = [];
    let total = 0;
    for (let i = 0; i < widths.length; i++) {
      xOffsets.push(total);
      total += widths[i];
    }

    const glyphMap = {};
    for (let i = 0; i < charOrder.length; i++) {
      glyphMap[charOrder[i]] = {
        x: xOffsets[i],
        w: widths[i]
      };
    }

    const startX = 20, startY = 20;
    let drawX = startX;
    ctx.fillStyle = "#ffffff";

    for (const ch of Array.from(text)) {
      const g = glyphMap[ch];
      if (!g) continue;

      for (let y = 0; y < image.length; y++) {
        for (let x = 0; x < g.w; x++) {
          if (image[y][g.x + x]) {
            ctx.fillRect((drawX + x) * scale, (startY + y) * scale, scale, scale);
          }
        }
      }

      drawX += g.w + kerning;
    }
  }

  async function updateFont() {
    try {
      const fontFile = document.getElementById("fontSelect").value;
      currentFont = await loadFont(fontFile);
      const md = currentFont;
      document.getElementById("metadata").textContent =
              `Font: ${md.fontName}\nAuthor: ${md.author}\n` +
              `Created: ${md.year}-${String(md.month).padStart(2, '0')}-${String(md.day).padStart(2, '0')}\n` +
              `Glyphs: ${md.charOrder.length}\nImage: ${md.fontImageWidth}x${md.fontImageHeight}\n` +
              `Kerning: ${md.kerning}, Leading: ${md.leading}`;
      updateRender();
    } catch (err) {
      console.error(err);
      alert("Failed to load font: " + err.message);
    }
  }

  function updateRender() {
    const text = document.getElementById("inputText").value;
    const scale = parseInt(document.getElementById("scaleSelect").value, 10);
    renderText(text, scale);
  }

  document.getElementById("fontSelect").addEventListener("change", updateFont);
  document.getElementById("scaleSelect").addEventListener("change", updateRender);
  document.getElementById("inputText").addEventListener("input", updateRender);

  updateFont();
</script>

<script>
  document.title = "TEST " + new Date().toLocaleTimeString();
</script>
</body>
</html>
